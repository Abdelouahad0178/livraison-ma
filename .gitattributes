# Normalisation automatique de l'encodage pour éviter les conflits CRLF/LF
# Tous les fichiers texte utilisent LF (Unix) dans le repository

# Auto detect text files and normalize line endings
* text=auto

# Force LF pour les fichiers source
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf

# Force LF pour les configs
*.yml text eol=lf
*.yaml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binaires - ne pas toucher
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
