rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return signedIn() ? userDoc().role : null;
    }

    function isStaff() {
      return role() == 'admin' || role() == 'directeur' || role() == 'agent'
          || role() == 'chef_agence' || role() == 'caissier'
          || role() == 'aide_agent' || role() == 'pointeur_encaisseur'
          || role() == 'encaisseur_central';
    }

    function isPointeurEncaisseur() {
      return role() == 'pointeur_encaisseur';
    }

    function isCentralCollector() {
      return role() == 'encaisseur_central';
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isAdminOrDirecteur() {
      return role() == 'admin' || role() == 'directeur';
    }

    function isAgentOrChef() {
      return role() == 'agent' || role() == 'chef_agence';
    }

    function isChefAgence() {
      return role() == 'chef_agence';
    }

    function isAideAgent() {
      return role() == 'aide_agent';
    }

    function isDeliveryWorker() {
      // Canonical roles only — normalize at write time in app code
      return role() == 'chauffeur' || role() == 'livreur';
    }

    function isNotBlocked() {
      return userDoc().blocked != true;
    }

    function userCity() {
      return signedIn() && userDoc().city is string ? userDoc().city : '';
    }

    function isAdminOrSameCity(city) {
      return isAdmin() || userCity() == city;
    }

    function isParcelCreator() {
      return signedIn() && resource.data.agentId == request.auth.uid;
    }

    function isChefOfAideAgentParcelAgency() {
      return role() == 'chef_agence'
        && (resource.data.agentRole == 'aide_agent' || resource.data.agentRole == 'client_portal')
        && (
          resource.data.originCity == userDoc().city
          || (resource.data.sender != null && resource.data.sender.city == userDoc().city)
          || (
            resource.data.agentId is string
            && exists(/databases/$(database)/documents/users/$(resource.data.agentId))
            && get(/databases/$(database)/documents/users/$(resource.data.agentId)).data.role == 'aide_agent'
            && get(/databases/$(database)/documents/users/$(resource.data.agentId)).data.city == userDoc().city
          )
        );
    }

    function protectedParcelBonFields() {
      return [
        'trackingId',
        'sender',
        'receiver',
        'weight',
        'nbColis',
        'natureOfGoods',
        'serviceType',
        'customerMode',
        'price',
        'codAmount',
        'agentId',
        'agentName',
        'originCity',
        'destinationCity',
        'clientId',
        'clientName',
        'createdAt'
      ];
    }

    function parcelCorrectionFields() {
      return [
        'sender',
        'receiver',
        'originCity',
        'destinationCity',
        'weight',
        'nbColis',
        'natureOfGoods',
        'serviceType',
        'customerMode',
        'price'
      ];
    }

    function deliveryAssignmentFields() {
      return [
        'deliveryDriverId',
        'deliveryDriverName',
        'deliverySectorId',
        'deliverySectorCode',
        'deliverySectorName',
        'deliveryVehicleId',
        'deliveryVehicleLabel',
        'deliveryAssignedAt',
        'deliveryAssignedBy'
      ];
    }

    function aideAgentValidationFields() {
      return [
        'agentId',
        'agentName',
        'agentRole',
        'aideAgentId',
        'aideAgentName',
        'validatedByChef',
        'validatedAt',
        'validatedById',
        'validatedByName',
        'aideEditUnlocked',
        'aideEditLockChangedAt',
        'aideEditLockChangedBy',
        'aideEditLockChangedByName',
        'destinationAgentId',
        'destinationAgentName',
        'deliveryAssignedBy',
        'receiverClientId'
      ];
    }

    function isDestinationAgencyChief() {
      return role() == 'chef_agence'
        && userDoc().city == resource.data.destinationCity;
    }

    function isAssignedDeliveryWorker() {
      return signedIn()
        && resource.data.deliveryDriverId == request.auth.uid;
    }

    function keepsDeliveredStatus() {
      return !(
        (resource.data.status == 'Livré' || resource.data.status == 'Livr\u00c3\u00a9')
        && request.resource.data.status != resource.data.status
      );
    }

    function ownsClient(clientId) {
      return signedIn()
        && exists(/databases/$(database)/documents/clients/$(clientId))
        && (
          get(/databases/$(database)/documents/clients/$(clientId)).data.portalUid == request.auth.uid
          || userDoc().clientId == clientId
        );
    }

    // â”€â”€ Colis : lecture publique (tracking)
    // codAmount modifiable uniquement par Admin (protection double : règle + code)
    match /parcels/{parcelId} {
      allow get:    if true;
      allow list:   if isStaff()
        || ownsClient(resource.data.clientId)
        || isDeliveryWorker()
        || (request.query.limit != null && request.query.limit <= 1);
      allow create: if (signedIn() && request.resource.data.agentId == request.auth.uid)
        || (isStaff() && isNotBlocked());
      allow delete: if ((resource.data.status != 'Livré' && resource.data.status != 'Livr\u00c3\u00a9') || isAdmin()) && (
        isAdmin()
        || isChefOfAideAgentParcelAgency()
        || (isAgentOrChef() && isParcelCreator())
        || (isAideAgent() && isParcelCreator() && resource.data.validatedByChef != true)
        || (isStaff() && !isAgentOrChef() && !isAideAgent())
      );
      // Correction du bon: poids/details uniquement, jamais COD/statut.
      // Autorisation volontairement limitee aux champs du bon pour eviter les rejets de role/token.
      allow update: if signedIn()
        && keepsDeliveredStatus()
        && resource.data.status != 'Livré'
        && resource.data.status != 'Livr\u00c3\u00a9'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(parcelCorrectionFields());
      allow update: if signedIn()
        && keepsDeliveredStatus()
        && request.auth.uid != resource.data.agentId
        && request.resource.data.validatedByChef == true
        && request.resource.data.validatedById == request.auth.uid
        && request.resource.data.agentId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(aideAgentValidationFields());
      // Chargement camion : seuls les champs transport sont modifiés
      allow update: if signedIn()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'chauffeurName', 'chauffeurPhone', 'status',
          'shipmentLoadedAt', 'visibleInDestinationAgency', 'history'
        ]);
      // Réception agence : prise en charge et arrivage de colis en transit
      allow update: if signedIn()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'visibleInDestinationAgency', 'destinationArrivedAt',
          'destinationAgentId', 'destinationAgentName', 'arrivedNbColis',
          'chefPointedAt', 'chefPointedBy', 'chefPointedById', 'chefPointedSource',
          'history'
        ]);
      // Assignation livraison locale : seuls les champs livraison sont modifiés
      allow update: if signedIn()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'deliveryDriverId', 'deliveryDriverName',
          'deliverySectorId', 'deliverySectorCode', 'deliverySectorName',
          'deliveryVehicleId', 'deliveryVehicleLabel',
          'deliveryAssignedAt', 'deliveryAssignedBy'
        ]);
      // Livreur local assigné : statut, encaissement, refus et signature uniquement sur ses colis
      allow update: if isAssignedDeliveryWorker()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'history',
          'lastLocation',
          'codStatus',
          'codPaymentType',
          'codCollectedAt',
          'codCollectedBy',
          'codCaisseEntryId',
          'portStatus',
          'portCollectedBy',
          'portCollectedById',
          'portCollectedAt',
          'signatureToken',
          'signatureTokenCreatedAt',
          'signatureConfirmedAt',
          'deliveryDriverId',
          'deliveryDriverName',
          'deliverySectorId',
          'deliverySectorCode',
          'deliverySectorName',
          'deliveryVehicleId',
          'deliveryVehicleLabel',
          'deliveryAssignedAt',
          'deliveryAssignedBy',
          'deliveryRejectedAt',
          'deliveryRejectedById',
          'deliveryRejectedBy'
        ]);
      // Pointeur-Encaisseur : réception port dû versé par un livreur
      allow update: if isPointeurEncaisseur()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'portPointeurId', 'portPointeurName', 'portPointeurAt'
        ]);
      // Pointeur-Encaisseur : remise COD après pointage (règlement créé)
      allow update: if isPointeurEncaisseur()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'codStatus', 'codRemisAt', 'codRemisBy'
        ]);
      // Pointeur-Encaisseur : remboursement RETOUR FOND sur colis retourné
      allow update: if isPointeurEncaisseur()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'codRefunded', 'codRefundedAt', 'codRefundedBy', 'codRefundedById'
        ]);
      // Pointeur-Encaisseur : envoi COD au chef d'agence
      allow update: if isPointeurEncaisseur()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'codSentToChef', 'codSentToChefAt', 'codSentToChefBy', 'codSentToChefById'
        ]);
      // Chef d'agence : validation du rapport COD du pointeur
      allow update: if isChefAgence()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'codValidatedByChef', 'codValidatedByChefAt', 'codValidatedByChefBy', 'codValidatedByChefById'
        ]);
      // Chef d'agence : envoi COD à l'agence source (avec/sans validation)
      allow update: if isChefAgence()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'codSentToSource', 'codSentToSourceAt', 'codSentToSourceBy', 'codSentToSourceById', 'codSentWithValidation'
        ]);
      // Agent/Chef d'agence : suivi COD (réception, envoi, confirmation, règlement)
      // Permet de mettre à jour les champs de traçage COD sans toucher aux données sensibles du bon.
      allow update: if isAgentOrChef()
        && keepsDeliveredStatus()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['codAmount'])
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedParcelBonFields())
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(deliveryAssignmentFields())
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(aideAgentValidationFields());
      // Approbation demande modification client par chef_agence ou agent
      allow update: if isAgentOrChef()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly([
             'receiver', 'serviceType', 'codPaymentType', 'codAmount', 'status',
             'modificationHistory', 'lastModificationRequestId',
             'lastModificationAt', 'lastModificationBy', 'lastModificationByRole'
           ]);
      // Encaisseur central : marquage des cheques societe vers fournisseurs.
      allow update: if isCentralCollector()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'codSenderPaid', 'codSenderPaidAt', 'codSenderPaidBy', 'codSenderPaidById',
          'centralSupplierPaid', 'centralSupplierPaymentId', 'centralSupplierPaymentStatus',
          'centralSupplierPreparedAt', 'centralSupplierPreparedBy', 'centralSupplierPreparedById',
          'centralSupplierPaidAt', 'centralSupplierPaidBy', 'centralSupplierPaidById',
          'centralChequeNum', 'centralChequeBank', 'centralChequeDate'
        ]);
      // Retour camion : l'agence qui a physiquement le colis retourné peut l'expédier
      // vers l'agence d'origine, sans toucher aux données sensibles du bon.
      allow update: if signedIn()
        && keepsDeliveredStatus()
        && request.resource.data.status == 'En transit retour'
        && (resource.data.status == 'Retourné' || resource.data.status == 'Retourné')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'returnShippedAt',
          'history',
          'sender',
          'receiver',
          'originCity',
          'destinationCity',
          'returnToCity',
          'arrivedNbColis'
        ]);
      // Retour direct depuis l'agence destination ou le livreur assigné.
      // Le bon est inversé pour repartir vers l'expéditeur, sans modifier les champs sensibles hors retour.
      allow update: if signedIn()
        && keepsDeliveredStatus()
        && request.resource.data.status == 'Retourné'
        && resource.data.status != 'Retourné'
        && (
          resource.data.destinationAgentId == request.auth.uid
          || resource.data.deliveryDriverId == request.auth.uid
          || (
            userDoc().city is string
            && (
              userDoc().city == resource.data.destinationCity
              || (resource.data.receiver != null && userDoc().city == resource.data.receiver.city)
            )
          )
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'sender',
          'receiver',
          'originCity',
          'destinationCity',
          'returnToCity',
          'createdByCity',
          'codAmount',
          'returnedAt',
          'returnReason',
          'arrivedNbColis',
          'history',
          'wasReturned',
          'returnedByDriverId',
          'returnedByDriverName',
          'deliveryDriverId',
          'deliveryDriverName',
          'deliverySectorId',
          'deliverySectorCode',
          'deliverySectorName',
          'deliveryVehicleId',
          'deliveryVehicleLabel',
          'deliveryAssignedAt',
          'deliveryAssignedBy'
        ]);
      allow update: if isStaff() && keepsDeliveredStatus() && (
        isAdmin()
        || isChefOfAideAgentParcelAgency()
        || (
          // Retour : tout le staff peut inverser expéditeur/destinataire
          request.resource.data.status == 'Retourné'
          && resource.data.status != 'Retourné'
          && !isAideAgent()
        )
        || (
          // Chargement retour sur camion inter-villes
          request.resource.data.status == 'En transit retour'
          && resource.data.status == 'Retourné'
          && !isAideAgent()
        )
        || (
          // Aide agent : modification de ses propres saisies non validées
          isAideAgent()
          && isParcelCreator()
          && (resource.data.validatedByChef != true || resource.data.aideEditUnlocked == true)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(aideAgentValidationFields())
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'codAmount'])
        )
        || (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['codAmount'])
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(aideAgentValidationFields())
          && !isAideAgent()
          && (
            !isAgentOrChef()
            || isParcelCreator()
            || (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedParcelBonFields())
              && (
                !request.resource.data.diff(resource.data).affectedKeys().hasAny(deliveryAssignmentFields())
                || isDestinationAgencyChief()
              )
            )
          )
        )
      );
    }

    // â”€â”€ Villes
    match /cities/{cityId} {
      allow read:  if true;
      allow write: if isStaff();
    }

    // â”€â”€ Paramètres globaux
    match /settings/{settingId} {
      // adminSetup lisible publiquement pour la page de login
      allow read:  if settingId == 'adminSetup' ? true : signedIn();
      allow write: if settingId == 'tariffs' ? isAdmin() : isStaff();
      // Création du document adminSetup lors de la première inscription admin
      allow create: if settingId == 'adminSetup'
        && !exists(/databases/$(database)/documents/settings/adminSetup);
    }

    // â”€â”€ Utilisateurs
    match /users/{userId} {
      allow read:   if isStaff() || (signedIn() && request.auth.uid == userId);
      // Première inscription admin : uniquement l'email hassan@gmail.com,
      // vérifié à la fois dans le token Firebase Auth ET dans le document,
      // et seulement si adminSetup n'existe pas encore.
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'admin'
        && request.auth.token.email == 'hassan@gmail.com'
        && request.resource.data.email == 'hassan@gmail.com'
        && !exists(/databases/$(database)/documents/settings/adminSetup);
      // Admin crée les autres comptes (sauf un autre admin)
      allow create: if isAdmin() && request.resource.data.role != 'admin';
      // Chef d'agence crée des livreurs locaux, aides agents et pointeurs-encaisseurs dans sa propre ville
      allow create: if role() == 'chef_agence'
        && request.resource.data.role in ['livreur', 'aide_agent', 'pointeur_encaisseur']
        && request.resource.data.city == userDoc().city;
      allow update: if isStaff();
      // Suppression : admin ou chef pour aide_agent/livreur/pointeur de sa ville
      allow delete: if isAdmin()
        || (role() == 'chef_agence'
          && resource.data.role in ['aide_agent', 'livreur', 'pointeur_encaisseur']
          && resource.data.city == userDoc().city);
    }

    // â”€â”€ Clients
    match /clients/{clientId} {
      allow read:  if isStaff() || (signedIn() && resource.data.portalUid == request.auth.uid);
      allow write: if isStaff();
    }

    // â”€â”€ Portails clients
    match /clientPortals/{token} {
      allow read, write: if isStaff();
    }

    // â”€â”€ Paiements
    match /payments/{paymentId} {
      allow read:  if isStaff() || ownsClient(resource.data.clientId);
      allow write: if isStaff();
    }

    // â”€â”€ Messages clients
    match /clientMessages/{messageId} {
      allow read: if isStaff() || ownsClient(resource.data.clientId);
      allow create: if ownsClient(request.resource.data.clientId)
        && request.resource.data.clientUid == request.auth.uid;
      // Marquer lu par le client
      allow update: if ownsClient(resource.data.clientId)
        && request.resource.data.clientId == resource.data.clientId
        && request.resource.data.clientUid == resource.data.clientUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readByClientAt','readByClientUid'])
        && request.resource.data.readByClientUid == request.auth.uid;
      // Réponse client dans le fil de conversation
      allow update: if ownsClient(resource.data.clientId)
        && request.resource.data.clientId == resource.data.clientId
        && request.resource.data.clientUid == resource.data.clientUid
        && request.resource.data.status == 'open'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies','lastReplyAt','status','readByStaffAt','readByStaffBy']);
      // Suppression d'un reply par le client (remplacement du tableau replies)
      allow update: if ownsClient(resource.data.clientId)
        && request.resource.data.clientId == resource.data.clientId
        && request.resource.data.clientUid == resource.data.clientUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies']);
      allow update: if isStaff();
      allow delete: if isStaff() || ownsClient(resource.data.clientId);
    }

    // â”€â”€ Demandes de modification colis (client → chef_agence)
    match /modificationRequests/{reqId} {
      allow read: if isStaff() || ownsClient(resource.data.clientId);
      allow create: if ownsClient(request.resource.data.clientId)
        && request.resource.data.clientUid == request.auth.uid;
      allow update: if isStaff();
      allow delete: if isStaff() || ownsClient(resource.data.clientId);
    }

    // â”€â”€ Caisse
    match /caisseEntries/{entryId} {
      allow read: if isAdmin()
        || (isStaff() && isNotBlocked() && (
          resource.data.city == userCity()
          || resource.data.agentId == request.auth.uid
          || resource.data.cashierId == request.auth.uid
          || resource.data.sourceAgentId == request.auth.uid
        ));
      allow create, update: if isStaff();
      // Protection: les versements livreurs ne peuvent être supprimés que par leur créateur ou un admin
      allow delete: if isAdmin()
        || isAdminOrDirecteur()
        // Chef d'agence peut supprimer les entrées de sa ville
        || (isChefAgence() && resource.data.city == userCity())
        || (isStaff() && (
          // Si createdById existe, vérifier que c'est le créateur
          (resource.data.createdById is string && resource.data.createdById == request.auth.uid)
          // Sinon utiliser cashierId ou agentId pour anciennes entrées
          || (!('createdById' in resource.data) && (
            resource.data.cashierId == request.auth.uid
            || resource.data.agentId == request.auth.uid
          ))
        ));
    }

    match /agencyCashes/{cashId} {
      allow read:  if isStaff();
      allow write: if isStaff();
    }

    match /caisseClotures/{id} {
      allow read, write: if isStaff();
    }

    match /caissierTransactions/{id} {
      allow read, write: if isStaff();
    }

    match /caissierRequests/{id} {
      allow read: if isAdmin()
        || (isStaff() && isNotBlocked() && (
          resource.data.city == userCity()
          || resource.data.caisserId == request.auth.uid
          || resource.data.requestedById == request.auth.uid
        ));
      allow write: if isStaff();
    }

    match /agentRemises/{id} {
      allow read, write: if isStaff();
    }

    match /agentCashRecoveryRequests/{id} {
      allow read: if isAdmin()
        || (isStaff() && isNotBlocked() && (
          resource.data.city == userCity()
          || resource.data.agentId == request.auth.uid
          || resource.data.cashierId == request.auth.uid
        ));
      allow write: if isStaff();
    }

    match /agentCodRequests/{id} {
      allow read, write: if isStaff();
    }

    // â”€â”€ Port dû chauffeurs (legacy â€” no longer used by UI)
    match /driverPortDuTransactions/{id} {
      allow read: if isStaff() || (signedIn() && request.auth.uid != null && resource.data.driverId == request.auth.uid);
      allow create:        if role() == 'admin' || role() == 'agent'
        || (signedIn()
          && request.resource.data.driverId == request.auth.uid
          && request.resource.data.type == 'versement'
          && request.resource.data.status == 'pending');
      allow update, delete: if role() == 'admin' || role() == 'agent' || role() == 'chef_agence';
    }

    // â”€â”€ Véhicules, logs directeur
    match /vehicles/{id} {
      allow read: if isStaff();
      allow write: if isAdminOrDirecteur();
    }

    match /directorLogs/{id} {
      allow read:   if isAdminOrDirecteur();
      allow create: if isStaff();
      allow update, delete: if isAdminOrDirecteur();
    }

    // â”€â”€ Secteurs
    match /sectors/{sectorId} {
      allow read:  if isStaff();
      allow write: if role() == 'admin' || role() == 'chef_agence';
    }

    // â”€â”€ Bons de ramassage (lots pré-imprimés)
    match /bonRamasageBatches/{batchId} {
      allow read:  if isStaff();
      allow write: if role() == 'admin' || role() == 'chef_agence';
    }

    // â”€â”€ Arrivages
    match /arrivages/{arrivageId} {
      allow read:   if signedIn();
      allow create: if isStaff() || isDeliveryWorker();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // â”€â”€ Transferts vers l'Admin
    match /adminTransfers/{id} {
      allow read:   if isStaff();
      allow create: if role() == 'admin' || role() == 'agent' || role() == 'chef_agence' || role() == 'caissier';
      allow update, delete: if isAdmin();
    }

    // â”€â”€ Signatures de livraison (accès public pour le destinataire)
    match /deliverySignatures/{parcelId} {
      // Lecture publique : le chauffeur et l'agent voient la signature en temps réel
      allow get: if true;
      allow list: if isStaff();
      // Création publique : uniquement si le token correspond à celui stocké dans le colis
      // Utiliser set au lieu de create pour permettre l'écrasement
      allow create, update: if request.resource.data.token != null
        && exists(/databases/$(database)/documents/parcels/$(parcelId))
        && get(/databases/$(database)/documents/parcels/$(parcelId)).data.signatureToken == request.resource.data.token;
      allow delete: if isStaff();
    }

    // â”€â”€ Remarques caissier
    match /caissierRemarks/{id} {
      allow read, write: if isStaff();
    }

    // â”€â”€ Règlements (Pointeur-Encaisseur)
    match /reglements/{reglementId} {
      allow read: if isAdmin()
        || (isStaff() && isNotBlocked() && (
          resource.data.agencyCity == userCity()
          || resource.data.villeExpedition == userCity()
          || resource.data.pointeurId == request.auth.uid
        ));
      allow create: if isAdmin()
        || (isPointeurEncaisseur()
          && request.resource.data.pointeurId == request.auth.uid
          && request.resource.data.agencyCity == userDoc().city);
      allow update: if isAdmin()
        || (isPointeurEncaisseur()
          && resource.data.agencyCity == userDoc().city
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'docVerified', 'docVerifiedAt', 'docVerifiedBy', 'docVerifiedById',
            'docControlStatus', 'docControlChecks', 'docControlNotes', 'updatedAt'
          ]))
        || (isPointeurEncaisseur()
          && resource.data.pointeurId == request.auth.uid
          && resource.data.agencyCity == userDoc().city
          && (resource.data.status == 'en_attente' || resource.data.status == 'encaisse'))
        || (role() == 'chef_agence' && resource.data.agencyCity == userDoc().city)
        || (role() == 'chef_agence'
          && resource.data.villeExpedition == userDoc().city
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'sourceReceived', 'sourceReceivedAt', 'sourceReceivedBy', 'sourceReceivedById',
            'sourceReceivedMode', 'sourceReceivedMontant', 'sourceReceivedBanque',
            'sourceReceivedNumeroPiece', 'sourceReceivedDateEcheance',
            'sourceDataMatches', 'sourceReceivedNote', 'updatedAt'
          ]));
      allow delete: if isAdmin()
        || (isPointeurEncaisseur()
          && resource.data.pointeurId == request.auth.uid
          && (resource.data.status == 'en_attente' || resource.data.status == 'encaisse'))
        || (role() == 'chef_agence' && resource.data.agencyCity == userDoc().city);
    }

    // â”€â”€ Rapports Règlements
    match /reglementsRapports/{rapportId} {
      allow read: if isAdmin()
        || (isStaff() && isNotBlocked() && (
          resource.data.agencyCity == userCity()
          || resource.data.pointeurId == request.auth.uid
        ));
      allow create: if isAdmin()
        || (isPointeurEncaisseur()
          && request.resource.data.pointeurId == request.auth.uid
          && request.resource.data.agencyCity == userDoc().city);
      allow update: if isAdmin()
        || (isPointeurEncaisseur()
          && resource.data.pointeurId == request.auth.uid
          && resource.data.status == 'brouillon')
        || (role() == 'chef_agence' && resource.data.agencyCity == userDoc().city);
      allow delete: if isAdmin()
        || (isPointeurEncaisseur()
          && resource.data.pointeurId == request.auth.uid
          && resource.data.status == 'brouillon');
    }

    // â”€â”€ Retour Documents (bordereaux de retour chèques/traites)
    match /retourDocuments/{id} {
      allow read: if isStaff();
      allow create: if isAdmin()
        || (isPointeurEncaisseur()
          && request.resource.data.pointeurId == request.auth.uid
          && request.resource.data.agencyCity == userDoc().city);
      allow update: if isAdmin()
        || (isPointeurEncaisseur() && resource.data.agencyCity == userDoc().city)
        || (role() == 'chef_agence'   && resource.data.agencyCity == userDoc().city);
      allow delete: if isAdmin()
        || (isPointeurEncaisseur()
          && resource.data.pointeurId == request.auth.uid
          && resource.data.status == 'brouillon');
    }

    // â”€â”€ Versements bancaires (RETOUR FOND)
    match /bankDeposits/{depositId} {
      allow read:          if isStaff();
      allow create:        if isStaff();
      allow update, delete: if isAdmin();
    }

    // â”€â”€ Notes agents
    match /agentNotes/{noteId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    // â”€â”€ Stats agrégées (écrites par Cloud Functions, lues par admin)
    match /stats/{statId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only (service account bypasses rules)
    }
    match /stats/{statId}/{sub=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // â”€â”€ Catch-all : lecture staff, écriture admin uniquement
    // (protège les collections non listées explicitement)
    // Encaisseur central : versements societe et paiements fournisseurs
    match /centralCodDeposits/{depositId} {
      allow read: if isAdmin() || isCentralCollector() || role() == 'chef_agence';
      allow create: if isAdmin() || role() == 'chef_agence';
      allow update: if isAdmin() || isCentralCollector();
      allow delete: if isAdmin();
    }

    match /centralSupplierPayments/{paymentId} {
      allow read, create, update: if isAdmin() || isCentralCollector();
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read:  if isStaff();
      allow write: if isAdmin();
    }
  }
}
