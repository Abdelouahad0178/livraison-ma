rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return signedIn() ? userDoc().role : null;
    }

    function isStaff() {
      return role() == 'admin' || role() == 'directeur' || role() == 'agent'
          || role() == 'chef_agence' || role() == 'caissier'
          || role() == 'aide_agent' || role() == 'pointeur_encaisseur'
          || role() == 'encaisseur_central';
    }

    function isPointeurEncaisseur() {
      return role() == 'pointeur_encaisseur';
    }

    function isCentralCollector() {
      return role() == 'encaisseur_central';
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isAdminOrDirecteur() {
      return role() == 'admin' || role() == 'directeur';
    }

    function isAgentOrChef() {
      return role() == 'agent' || role() == 'chef_agence';
    }

    function isChefAgence() {
      return role() == 'chef_agence';
    }

    function isAideAgent() {
      return role() == 'aide_agent';
    }

    function isDeliveryWorker() {
      // Canonical roles only Гўв‚¬вЂќ normalize at write time in app code
      return role() == 'chauffeur' || role() == 'livreur';
    }

    function isNotBlocked() {
      return userDoc().blocked != true;
    }

    function userCity() {
      return signedIn() && userDoc().city is string ? userDoc().city : '';
    }

    function isAdminOrSameCity(city) {
      return isAdmin() || userCity() == city;
    }

    function isParcelCreator() {
      return signedIn() && resource.data.agentId == request.auth.uid;
    }

    function isChefOfAideAgentParcelAgency() {
      return role() == 'chef_agence'
        && (resource.data.agentRole == 'aide_agent' || resource.data.agentRole == 'client_portal')
        && (
          resource.data.originCity == userDoc().city
          || (resource.data.sender != null && resource.data.sender.city == userDoc().city)
          || (
            resource.data.agentId is string
            && exists(/databases/$(database)/documents/users/$(resource.data.agentId))
            && get(/databases/$(database)/documents/users/$(resource.data.agentId)).data.role == 'aide_agent'
            && get(/databases/$(database)/documents/users/$(resource.data.agentId)).data.city == userDoc().city
          )
        );
    }

    function protectedParcelBonFields() {
      return [
        'trackingId',
        'sender',
        'receiver',
        'weight',
        'nbColis',
        'natureOfGoods',
        'serviceType',
        'customerMode',
        'price',
        'codAmount',
        'agentId',
        'agentName',
        'originCity',
        'destinationCity',
        'clientId',
        'clientName',
        'createdAt'
      ];
    }

    function parcelCorrectionFields() {
      return [
        'sender',
        'receiver',
        'originCity',
        'destinationCity',
        'weight',
        'nbColis',
        'natureOfGoods',
        'serviceType',
        'customerMode',
        'price'
      ];
    }

    function deliveryAssignmentFields() {
      return [
        'deliveryDriverId',
        'deliveryDriverName',
        'deliverySectorId',
        'deliverySectorCode',
        'deliverySectorName',
        'deliveryVehicleId',
        'deliveryVehicleLabel',
        'deliveryAssignedAt',
        'deliveryAssignedBy'
      ];
    }

    function aideAgentValidationFields() {
      return [
        'agentId',
        'agentName',
        'agentRole',
        'aideAgentId',
        'aideAgentName',
        'validatedByChef',
        'validatedAt',
        'validatedById',
        'validatedByName',
        'aideEditUnlocked',
        'aideEditLockChangedAt',
        'aideEditLockChangedBy',
        'aideEditLockChangedByName',
        'destinationAgentId',
        'destinationAgentName',
        'deliveryAssignedBy',
        'receiverClientId'
      ];
    }

    function isDestinationAgencyChief() {
      return role() == 'chef_agence'
        && userDoc().city == resource.data.destinationCity;
    }

    function isAssignedDeliveryWorker() {
      return signedIn()
        && resource.data.deliveryDriverId == request.auth.uid;
    }

    function keepsDeliveredStatus() {
      // Autoriser la transition "LivrГ©" в†’ "RetournГ©" (retour de colis)
      let isReturnTransition = request.resource.data.status == 'RetournГ©';
      
      // Bloquer autres changements de statut depuis "LivrГ©"
      let blocksOtherChanges = (resource.data.status == 'LivrГ©' || resource.data.status == 'LivrГѓВ©')
        && request.resource.data.status != resource.data.status
        && request.resource.data.status != 'RetournГ©';

      return isReturnTransition || !blocksOtherChanges;
    }

    function ownsClient(clientId) {
      return signedIn()
        && exists(/databases/$(database)/documents/clients/$(clientId))
        && (
          get(/databases/$(database)/documents/clients/$(clientId)).data.portalUid == request.auth.uid
          || userDoc().clientId == clientId
        );
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Colis : lecture publique (tracking)
    // codAmount modifiable uniquement par Admin (protection double : rГѓВЁgle + code)
    match /parcels/{parcelId} {
      allow get:    if true;
      allow list:   if isStaff()
        || ownsClient(resource.data.clientId)
        || isDeliveryWorker()
        || (request.query.limit != null && request.query.limit <= 1);
      allow create: if (signedIn() && request.resource.data.agentId == request.auth.uid)
        || (isStaff() && isNotBlocked());
      allow delete: if ((resource.data.status != 'LivrГѓВ©' && resource.data.status != 'Livr\u00c3\u00a9') || isAdmin()) && (
        isAdmin()
        || isChefOfAideAgentParcelAgency()
        || (isAgentOrChef() && isParcelCreator())
        || (isAideAgent() && isParcelCreator() && resource.data.validatedByChef != true)
        || (isStaff() && !isAgentOrChef() && !isAideAgent())
      );
      // Correction du bon: poids/details uniquement, jamais COD/statut.
      // Autorisation volontairement limitee aux champs du bon pour eviter les rejets de role/token.
      // в­ђ RГ€GLE PRIORITAIRE : Retour de colis (depuis N'IMPORTE QUEL statut в†’ RetournГ©)
      // Autorise TOUTES les modifications nГ©cessaires pour markParcelAsReturned()
      allow update: if signedIn() && request.resource.data.status == 'RetournГ©';
      // в­ђ RГ€GLE : RГ©essayer livraison (RetournГ© в†’ En livraison)
      // Permet de remettre un colis retournГ© en circulation
      allow update: if signedIn()
        && resource.data.status == 'RetournГ©'
        && request.resource.data.status == 'En livraison';
      allow update: if signedIn()
        && keepsDeliveredStatus()
        && resource.data.status != 'LivrГѓВ©'
        && resource.data.status != 'Livr\u00c3\u00a9'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(parcelCorrectionFields());
      allow update: if signedIn()
        && keepsDeliveredStatus()
        && request.auth.uid != resource.data.agentId
        && request.resource.data.validatedByChef == true
        && request.resource.data.validatedById == request.auth.uid
        && request.resource.data.agentId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(aideAgentValidationFields());
      // Chargement camion : seuls les champs transport sont modifiГѓВ©s
      allow update: if signedIn()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'chauffeurName', 'chauffeurPhone', 'status',
          'shipmentLoadedAt', 'visibleInDestinationAgency', 'history'
        ]);
      // в­ђ POINTAGE ARRIVAGE : autoriser sans vГ©rifier keepsDeliveredStatus
      // (car le pointage peut se faire mГЄme si le colis a un statut particulier)
      allow update: if signedIn()
        && isStaff()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'visibleInDestinationAgency', 'destinationArrivedAt',
          'destinationAgentId', 'destinationAgentName', 'arrivedNbColis',
          'chefPointedAt', 'chefPointedBy', 'chefPointedById', 'chefPointedSource',
          'history'
        ]);
      // в­ђ VALIDATION ARRIVГ‰E RETOUR : validation arrivГ©e colis retournГ©
      // Autorise mise Г  jour avec destinationArrivedAt (=validation retour)
      allow update: if signedIn()
        && 'destinationArrivedAt' in request.resource.data
        && 'history' in request.resource.data;
      // RГѓВ©ception agence : prise en charge et arrivage de colis en transit
      allow update: if signedIn()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'visibleInDestinationAgency', 'destinationArrivedAt',
          'destinationAgentId', 'destinationAgentName', 'arrivedNbColis',
          'chefPointedAt', 'chefPointedBy', 'chefPointedById', 'chefPointedSource',
          'history'
        ]);
      // Assignation livraison locale : seuls les champs livraison sont modifiГѓВ©s
      allow update: if signedIn()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'deliveryDriverId', 'deliveryDriverName',
          'deliverySectorId', 'deliverySectorCode', 'deliverySectorName',
          'deliveryVehicleId', 'deliveryVehicleLabel',
          'deliveryAssignedAt', 'deliveryAssignedBy'
        ]);
      // в­ђ Staff : gГ©nГ©rer token de signature (agents, chauffeurs, etc.)
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'signatureToken',
          'signatureTokenCreatedAt'
        ]);
      // в­ђ Staff : gГ©nГ©rer token de signature de retour
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'returnSignatureToken',
          'returnSignatureTokenCreatedAt'
        ]);
      // в­ђ Staff : confirmer signature normale (LivrГ©)
      allow update: if signedIn()
        && request.resource.data.status == 'LivrГ©'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'signatureToken',
          'signatureConfirmedAt',
          'signatureMethod',
          'history'
        ]);
      // в­ђ Staff : confirmer signature de retour (Retour finalisГ©)
      allow update: if signedIn()
        && request.resource.data.status == 'Retour finalisГ©'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'returnSignatureToken',
          'returnSignatureConfirmedAt',
          'signatureMethod',
          'history'
        ]);
      // Livreur local assignГѓВ© : statut, encaissement, refus et signature uniquement sur ses colis
      allow update: if isAssignedDeliveryWorker()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'history',
          'lastLocation',
          'codStatus',
          'codPaymentType',
          'codCollectedAt',
          'codCollectedBy',
          'codCaisseEntryId',
          'portStatus',
          'portCollectedBy',
          'portCollectedById',
          'portCollectedAt',
          'signatureToken',
          'signatureTokenCreatedAt',
          'signatureConfirmedAt',
          'returnSignatureToken',
          'returnSignatureTokenCreatedAt',
          'returnSignatureConfirmedAt',
          'deliveryDriverId',
          'deliveryDriverName',
          'deliverySectorId',
          'deliverySectorCode',
          'deliverySectorName',
          'deliveryVehicleId',
          'deliveryVehicleLabel',
          'deliveryAssignedAt',
          'deliveryAssignedBy',
          'deliveryRejectedAt',
          'deliveryRejectedById',
          'deliveryRejectedBy'
        ]);
      // Pointeur-Encaisseur : rГѓВ©ception port dГѓВ» versГѓВ© par un livreur
      allow update: if isPointeurEncaisseur()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'portPointeurId', 'portPointeurName', 'portPointeurAt'
        ]);
      // Pointeur-Encaisseur : remise COD aprГѓВЁs pointage (rГѓВЁglement crГѓВ©ГѓВ©)
      allow update: if isPointeurEncaisseur()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'codStatus', 'codRemisAt', 'codRemisBy'
        ]);
      // Pointeur-Encaisseur : remboursement RETOUR FOND sur colis retournГѓВ©
      allow update: if isPointeurEncaisseur()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'codRefunded', 'codRefundedAt', 'codRefundedBy', 'codRefundedById'
        ]);
      // Pointeur-Encaisseur : envoi COD au chef d'agence
      allow update: if isPointeurEncaisseur()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'codSentToChef', 'codSentToChefAt', 'codSentToChefBy', 'codSentToChefById'
        ]);
      // Chef d'agence : validation du rapport COD du pointeur
      allow update: if isChefAgence()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'codValidatedByChef', 'codValidatedByChefAt', 'codValidatedByChefBy', 'codValidatedByChefById'
        ]);
      // Chef d'agence : envoi COD ГѓВ  l'agence source (avec/sans validation)
      allow update: if isChefAgence()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'codSentToSource', 'codSentToSourceAt', 'codSentToSourceBy', 'codSentToSourceById', 'codSentWithValidation'
        ]);
      // Agent/Chef d'agence : suivi COD (rГѓВ©ception, envoi, confirmation, rГѓВЁglement)
      // Permet de mettre ГѓВ  jour les champs de traГѓВ§age COD sans toucher aux donnГѓВ©es sensibles du bon.
      allow update: if isAgentOrChef()
        && keepsDeliveredStatus()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['codAmount'])
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedParcelBonFields())
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(deliveryAssignmentFields())
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(aideAgentValidationFields());
      // Approbation demande modification client par chef_agence ou agent
      allow update: if isAgentOrChef()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly([
             'receiver', 'serviceType', 'codPaymentType', 'codAmount', 'status',
             'modificationHistory', 'lastModificationRequestId',
             'lastModificationAt', 'lastModificationBy', 'lastModificationByRole'
           ]);
      // Encaisseur central : marquage des cheques societe vers fournisseurs.
      allow update: if isCentralCollector()
        && keepsDeliveredStatus()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'codSenderPaid', 'codSenderPaidAt', 'codSenderPaidBy', 'codSenderPaidById',
          'centralSupplierPaid', 'centralSupplierPaymentId', 'centralSupplierPaymentStatus',
          'centralSupplierPreparedAt', 'centralSupplierPreparedBy', 'centralSupplierPreparedById',
          'centralSupplierPaidAt', 'centralSupplierPaidBy', 'centralSupplierPaidById',
          'centralChequeNum', 'centralChequeBank', 'centralChequeDate'
        ]);
      // Retour camion : l'agence qui a physiquement le colis retournГѓВ© peut l'expГѓВ©dier
      // vers l'agence d'origine, sans toucher aux donnГѓВ©es sensibles du bon.
      allow update: if signedIn()
        && keepsDeliveredStatus()
        && request.resource.data.status == 'Retour en transit'
        && (resource.data.status == 'RetournГѓВ©' || resource.data.status == 'RetournГѓВ©')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'returnShippedAt',
          'history',
          'sender',
          'receiver',
          'originCity',
          'destinationCity',
          'returnToCity',
          'arrivedNbColis'
        ]);
      // Retour direct depuis l'agence destination ou le livreur assignГѓВ©.
      // Le bon est inversГѓВ© pour repartir vers l'expГѓВ©diteur, sans modifier les champs sensibles hors retour.
      allow update: if signedIn()
        && keepsDeliveredStatus()
        && request.resource.data.status == 'RetournГѓВ©'
        && resource.data.status != 'RetournГѓВ©'
        && (
          resource.data.destinationAgentId == request.auth.uid
          || resource.data.deliveryDriverId == request.auth.uid
          || (
            userDoc().city is string
            && (
              userDoc().city == resource.data.destinationCity
              || (resource.data.receiver != null && userDoc().city == resource.data.receiver.city)
            )
          )
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'sender',
          'receiver',
          'originCity',
          'destinationCity',
          'returnToCity',
          'createdByCity',
          'codAmount',
          'returnedAt',
          'returnReason',
          'arrivedNbColis',
          'history',
          'wasReturned',
          'returnedByDriverId',
          'returnedByDriverName',
          'deliveryDriverId',
          'deliveryDriverName',
          'deliverySectorId',
          'deliverySectorCode',
          'deliverySectorName',
          'deliveryVehicleId',
          'deliveryVehicleLabel',
          'deliveryAssignedAt',
          'deliveryAssignedBy'
        ]);
      allow update: if isStaff() && keepsDeliveredStatus() && (
        isAdmin()
        || isChefOfAideAgentParcelAgency()
        || (
          // Retour : tout le staff peut inverser expГѓВ©diteur/destinataire
          request.resource.data.status == 'RetournГѓВ©'
          && resource.data.status != 'RetournГѓВ©'
          && !isAideAgent()
        )
        || (
          // Chargement retour sur camion inter-villes
          request.resource.data.status == 'Retour en transit'
          && resource.data.status == 'RetournГѓВ©'
          && !isAideAgent()
        )
        || (
          // Aide agent : modification de ses propres saisies non validГѓВ©es
          isAideAgent()
          && isParcelCreator()
          && (resource.data.validatedByChef != true || resource.data.aideEditUnlocked == true)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(aideAgentValidationFields())
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'codAmount'])
        )
        || (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['codAmount'])
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(aideAgentValidationFields())
          && !isAideAgent()
          && (
            !isAgentOrChef()
            || isParcelCreator()
            || (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedParcelBonFields())
              && (
                !request.resource.data.diff(resource.data).affectedKeys().hasAny(deliveryAssignmentFields())
                || isDestinationAgencyChief()
              )
            )
          )
        )
      );
      // REGLE RETOUR COLIS
      allow update: if signedIn() && request.resource.data.status == "RetournГ©";
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Villes
    match /cities/{cityId} {
      allow read:  if true;
      allow write: if isStaff();
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ ParamГѓВЁtres globaux
    match /settings/{settingId} {
      // adminSetup lisible publiquement pour la page de login
      allow read:  if settingId == 'adminSetup' ? true : signedIn();
      allow write: if settingId == 'tariffs' ? isAdmin() : isStaff();
      // CrГѓВ©ation du document adminSetup lors de la premiГѓВЁre inscription admin
      allow create: if settingId == 'adminSetup'
        && !exists(/databases/$(database)/documents/settings/adminSetup);
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Utilisateurs
    match /users/{userId} {
      allow read:   if isStaff() || (signedIn() && request.auth.uid == userId);
      // PremiГѓВЁre inscription admin : uniquement l'email hassan@gmail.com,
      // vГѓВ©rifiГѓВ© ГѓВ  la fois dans le token Firebase Auth ET dans le document,
      // et seulement si adminSetup n'existe pas encore.
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'admin'
        && request.auth.token.email == 'hassan@gmail.com'
        && request.resource.data.email == 'hassan@gmail.com'
        && !exists(/databases/$(database)/documents/settings/adminSetup);
      // Admin crГѓВ©e les autres comptes (sauf un autre admin)
      allow create: if isAdmin() && request.resource.data.role != 'admin';
      // Chef d'agence crГѓВ©e des livreurs locaux, aides agents et pointeurs-encaisseurs dans sa propre ville
      allow create: if role() == 'chef_agence'
        && request.resource.data.role in ['livreur', 'aide_agent', 'pointeur_encaisseur']
        && request.resource.data.city == userDoc().city;
      // CrГ©ation de comptes portail clients (expГ©diteurs/destinataires)
      // Par l'utilisateur lui-mГЄme OU par le staff
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role in ['client-expediteur', 'client-destinataire'];
      // Staff peut crГ©er des comptes portail pour les clients
      allow create: if isStaff()
        && request.resource.data.role in ['client-expediteur', 'client-destinataire'];
      allow update: if isStaff();
      // Suppression : admin ou chef pour aide_agent/livreur/pointeur de sa ville
      allow delete: if isAdmin()
        || (role() == 'chef_agence'
          && resource.data.role in ['aide_agent', 'livreur', 'pointeur_encaisseur']
          && resource.data.city == userDoc().city);
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Clients
    match /clients/{clientId} {
      allow read:  if isStaff() || (signedIn() && resource.data.portalUid == request.auth.uid);
      allow write: if isStaff();
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Portails clients
    match /clientPortals/{token} {
      allow read, write: if isStaff();
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Paiements
    match /payments/{paymentId} {
      allow read:  if isStaff() || ownsClient(resource.data.clientId);
      allow write: if isStaff();
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Messages clients
    match /clientMessages/{messageId} {
      allow read: if isStaff() || ownsClient(resource.data.clientId);
      allow create: if ownsClient(request.resource.data.clientId)
        && request.resource.data.clientUid == request.auth.uid;
      // Marquer lu par le client
      allow update: if ownsClient(resource.data.clientId)
        && request.resource.data.clientId == resource.data.clientId
        && request.resource.data.clientUid == resource.data.clientUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readByClientAt','readByClientUid'])
        && request.resource.data.readByClientUid == request.auth.uid;
      // RГѓВ©ponse client dans le fil de conversation
      allow update: if ownsClient(resource.data.clientId)
        && request.resource.data.clientId == resource.data.clientId
        && request.resource.data.clientUid == resource.data.clientUid
        && request.resource.data.status == 'open'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies','lastReplyAt','status','readByStaffAt','readByStaffBy']);
      // Suppression d'un reply par le client (remplacement du tableau replies)
      allow update: if ownsClient(resource.data.clientId)
        && request.resource.data.clientId == resource.data.clientId
        && request.resource.data.clientUid == resource.data.clientUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies']);
      allow update: if isStaff();
      allow delete: if isStaff() || ownsClient(resource.data.clientId);
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Demandes de modification colis (client ГўвЂ вЂ™ chef_agence)
    match /modificationRequests/{reqId} {
      allow read: if isStaff() || ownsClient(resource.data.clientId);
      allow create: if ownsClient(request.resource.data.clientId)
        && request.resource.data.clientUid == request.auth.uid;
      allow update: if isStaff();
      allow delete: if isStaff() || ownsClient(resource.data.clientId);
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Caisse
    match /caisseEntries/{entryId} {
      allow read: if isAdmin()
        || (isStaff() && isNotBlocked() && (
          resource.data.city == userCity()
          || resource.data.agentId == request.auth.uid
          || resource.data.cashierId == request.auth.uid
          || resource.data.sourceAgentId == request.auth.uid
        ));
      allow create, update: if isStaff();
      // Protection: les versements livreurs ne peuvent ГѓВЄtre supprimГѓВ©s que par leur crГѓВ©ateur ou un admin
      allow delete: if isAdmin()
        || isAdminOrDirecteur()
        // Chef d'agence peut supprimer les entrГѓВ©es de sa ville
        || (isChefAgence() && resource.data.city == userCity())
        || (isStaff() && (
          // Si createdById existe, vГѓВ©rifier que c'est le crГѓВ©ateur
          (resource.data.createdById is string && resource.data.createdById == request.auth.uid)
          // Sinon utiliser cashierId ou agentId pour anciennes entrГѓВ©es
          || (!('createdById' in resource.data) && (
            resource.data.cashierId == request.auth.uid
            || resource.data.agentId == request.auth.uid
          ))
        ));
    }

    match /agencyCashes/{cashId} {
      allow read:  if isStaff();
      allow write: if isStaff();
    }

    match /caisseClotures/{id} {
      allow read, write: if isStaff();
    }

    match /caissierTransactions/{id} {
      allow read, write: if isStaff();
    }

    match /caissierRequests/{id} {
      allow read: if isAdmin()
        || (isStaff() && isNotBlocked() && (
          resource.data.city == userCity()
          || resource.data.caisserId == request.auth.uid
          || resource.data.requestedById == request.auth.uid
        ));
      allow write: if isStaff();
    }

    match /agentRemises/{id} {
      allow read, write: if isStaff();
    }

    match /agentCashRecoveryRequests/{id} {
      allow read: if isAdmin()
        || (isStaff() && isNotBlocked() && (
          resource.data.city == userCity()
          || resource.data.agentId == request.auth.uid
          || resource.data.cashierId == request.auth.uid
        ));
      allow write: if isStaff();
    }

    match /agentCodRequests/{id} {
      allow read, write: if isStaff();
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Port dГѓВ» chauffeurs (legacy ГѓВўГўвЂљВ¬Гўв‚¬Вќ no longer used by UI)
    match /driverPortDuTransactions/{id} {
      allow read: if isStaff() || (signedIn() && request.auth.uid != null && resource.data.driverId == request.auth.uid);
      allow create:        if role() == 'admin' || role() == 'agent'
        || (signedIn()
          && request.resource.data.driverId == request.auth.uid
          && request.resource.data.type == 'versement'
          && request.resource.data.status == 'pending');
      allow update, delete: if role() == 'admin' || role() == 'agent' || role() == 'chef_agence';
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ VГѓВ©hicules, logs directeur
    match /vehicles/{id} {
      allow read: if isStaff();
      allow write: if isAdminOrDirecteur();
    }

    match /directorLogs/{id} {
      allow read:   if isAdminOrDirecteur();
      allow create: if isStaff();
      allow update, delete: if isAdminOrDirecteur();
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Secteurs
    match /sectors/{sectorId} {
      allow read:  if isStaff();
      allow write: if role() == 'admin' || role() == 'chef_agence';
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Bons de ramassage (lots prГѓВ©-imprimГѓВ©s)
    match /bonRamasageBatches/{batchId} {
      allow read:  if isStaff();
      allow write: if role() == 'admin' || role() == 'chef_agence';
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Arrivages
    match /arrivages/{arrivageId} {
      allow read:   if signedIn();
      allow create: if isStaff() || isDeliveryWorker();
      // Autoriser la modification par tout le staff pour le pointage
      allow update: if signedIn() && (isStaff() || isDeliveryWorker());
      // TEMPORAIRE: Permettre au staff de supprimer (pour nettoyage)
      // TODO: Remettre "allow delete: if isAdmin();" aprГЁs nettoyage
      allow delete: if isStaff();
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Transferts vers l'Admin
    match /adminTransfers/{id} {
      allow read:   if isStaff();
      allow create: if role() == 'admin' || role() == 'agent' || role() == 'chef_agence' || role() == 'caissier';
      allow update, delete: if isAdmin();
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Signatures de livraison (accГѓВЁs public pour le destinataire)
    // ГѓВўГўв‚¬ГўвЂљВ¬ГѓВўГўв‚¬ГўвЂљВ¬ Signatures de livraison (accГѓВЁs public pour le destinataire)
    // Supporte signatures normales ({parcelId}) ET signatures de retour ({parcelId}_return)
    match /deliverySignatures/{signatureId} {
      // Lecture publique : le chauffeur et l'agent voient la signature en temps rГѓВ©el
      allow get: if true;
      allow list: if isStaff();
      // CrГѓВ©ation publique : uniquement si le token correspond Гѓ  celui stockГѓВ© dans le colis
      // Le signatureId peut ГЄtre {parcelId} OU {parcelId}_return
      allow create, update: if request.resource.data.token != null
        && request.resource.data.parcelId != null
        && exists(/databases/$(database)/documents/parcels/$(request.resource.data.parcelId))
        && (
          get(/databases/$(database)/documents/parcels/$(request.resource.data.parcelId)).data.signatureToken == request.resource.data.token
          || get(/databases/$(database)/documents/parcels/$(request.resource.data.parcelId)).data.returnSignatureToken == request.resource.data.token
        );
      allow delete: if isStaff();
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Remarques caissier
    match /caissierRemarks/{id} {
      allow read, write: if isStaff();
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ RГѓВЁglements (Pointeur-Encaisseur)
    match /reglements/{reglementId} {
      allow read: if isAdmin()
        || (isStaff() && isNotBlocked() && (
          resource.data.agencyCity == userCity()
          || resource.data.villeExpedition == userCity()
          || resource.data.pointeurId == request.auth.uid
        ));
      allow create: if isAdmin()
        || (isPointeurEncaisseur()
          && request.resource.data.pointeurId == request.auth.uid
          && request.resource.data.agencyCity == userDoc().city);
      allow update: if isAdmin()
        || (isPointeurEncaisseur()
          && resource.data.agencyCity == userDoc().city
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'docVerified', 'docVerifiedAt', 'docVerifiedBy', 'docVerifiedById',
            'docControlStatus', 'docControlChecks', 'docControlNotes', 'updatedAt'
          ]))
        || (isPointeurEncaisseur()
          && resource.data.pointeurId == request.auth.uid
          && resource.data.agencyCity == userDoc().city
          && (resource.data.status == 'en_attente' || resource.data.status == 'encaisse'))
        || (role() == 'chef_agence' && resource.data.agencyCity == userDoc().city)
        || (role() == 'chef_agence'
          && resource.data.villeExpedition == userDoc().city
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'sourceReceived', 'sourceReceivedAt', 'sourceReceivedBy', 'sourceReceivedById',
            'sourceReceivedMode', 'sourceReceivedMontant', 'sourceReceivedBanque',
            'sourceReceivedNumeroPiece', 'sourceReceivedDateEcheance',
            'sourceDataMatches', 'sourceReceivedNote', 'updatedAt'
          ]));
      allow delete: if isAdmin()
        || (isPointeurEncaisseur()
          && resource.data.pointeurId == request.auth.uid
          && (resource.data.status == 'en_attente' || resource.data.status == 'encaisse'))
        || (role() == 'chef_agence' && resource.data.agencyCity == userDoc().city);
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Rapports RГѓВЁglements
    match /reglementsRapports/{rapportId} {
      allow read: if isAdmin()
        || (isStaff() && isNotBlocked() && (
          resource.data.agencyCity == userCity()
          || resource.data.pointeurId == request.auth.uid
        ));
      allow create: if isAdmin()
        || (isPointeurEncaisseur()
          && request.resource.data.pointeurId == request.auth.uid
          && request.resource.data.agencyCity == userDoc().city);
      allow update: if isAdmin()
        || (isPointeurEncaisseur()
          && resource.data.pointeurId == request.auth.uid
          && resource.data.status == 'brouillon')
        || (role() == 'chef_agence' && resource.data.agencyCity == userDoc().city);
      allow delete: if isAdmin()
        || (isPointeurEncaisseur()
          && resource.data.pointeurId == request.auth.uid
          && resource.data.status == 'brouillon');
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Retour Documents (bordereaux de retour chГѓВЁques/traites)
    match /retourDocuments/{id} {
      allow read: if isStaff();
      allow create: if isAdmin()
        || (isPointeurEncaisseur()
          && request.resource.data.pointeurId == request.auth.uid
          && request.resource.data.agencyCity == userDoc().city);
      allow update: if isAdmin()
        || (isPointeurEncaisseur() && resource.data.agencyCity == userDoc().city)
        || (role() == 'chef_agence'   && resource.data.agencyCity == userDoc().city);
      allow delete: if isAdmin()
        || (isPointeurEncaisseur()
          && resource.data.pointeurId == request.auth.uid
          && resource.data.status == 'brouillon');
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Versements bancaires (RETOUR FOND)
    match /bankDeposits/{depositId} {
      allow read:          if isStaff();
      allow create:        if isStaff();
      allow update, delete: if isAdmin();
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Notes agents
    match /agentNotes/{noteId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Stats agrГѓВ©gГѓВ©es (ГѓВ©crites par Cloud Functions, lues par admin)
    match /stats/{statId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only (service account bypasses rules)
    }
    match /stats/{statId}/{sub=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ГѓВўГўв‚¬ВќГўвЂљВ¬ГѓВўГўв‚¬ВќГўвЂљВ¬ Catch-all : lecture staff, ГѓВ©criture admin uniquement
    // (protГѓВЁge les collections non listГѓВ©es explicitement)
    // Encaisseur central : versements societe et paiements fournisseurs
    match /centralCodDeposits/{depositId} {
      allow read: if isAdmin() || isCentralCollector() || role() == 'chef_agence';
      allow create: if isAdmin() || role() == 'chef_agence';
      allow update: if isAdmin() || isCentralCollector();
      allow delete: if isAdmin();
    }

    match /centralSupplierPayments/{paymentId} {
      allow read, create, update: if isAdmin() || isCentralCollector();
      allow delete: if isAdmin();
    }

    // Comptes portail (particuliers et clients)
    match /portalAccounts/{accountId} {
      allow read: if isStaff() || (signedIn() && request.auth.uid == accountId);
      // CrГ©ation : staff OU utilisateur crГ©ant son propre compte (accountId = uid)
      allow create: if isStaff()
        || (signedIn() && request.auth.uid == accountId && request.resource.data.uid == request.auth.uid);
      allow update: if isStaff() || (signedIn() && request.auth.uid == accountId);
      allow delete: if isStaff();
    }

    // DГ©clarations de colis perdus
    match /lostParcels/{lostParcelId} {
      allow read: if isStaff() || isDeliveryWorker();
      // CrГ©ation : tout le staff ET les chauffeurs/livreurs peuvent dГ©clarer un colis perdu
      allow create: if (isStaff() || isDeliveryWorker()) && signedIn();
      // Mise Г  jour : rГ©ponses des agences, changements de statut
      allow update: if isStaff();
      // Suppression : admin, chef d'agence, ou dГ©clarateur original
      allow delete: if isAdmin()
        || role() == 'chef_agence'
        || (signedIn() && resource.data.declaredBy.uid == request.auth.uid);
    }

    match /{document=**} {
      allow read:  if isStaff();
      allow write: if isAdmin();
    }
  }
}
